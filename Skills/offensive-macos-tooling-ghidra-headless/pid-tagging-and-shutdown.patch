+
+    # ------------------------------------------------------------------
+    # Lifecycle / lab-health integration (SHAKEDOWN_NOTES.md #24/#25).
+    #
+    # The PASS-001 stop condition was: a prior session crashed leaving its
+    # ghidra-headless-mcp subprocess holding an exclusive .lock on a Ghidra
+    # project; the next session couldn't open the project and `ps` couldn't
+    # tell zombie from live MCP. shutdown() cleanly closes every session
+    # (releasing each project lock) on SIGTERM/SIGINT/atexit, and the
+    # sidecar gives lab-health.sh a structured view of which PID holds
+    # which project + lockfile.
+    # ------------------------------------------------------------------
+
+    def _write_sidecar(self) -> None:
+        try:
+            self._sidecar_dir.mkdir(parents=True, exist_ok=True)
+            payload = {
+                "pid": os.getpid(),
+                "started_at": self._sidecar_started_at,
+                "claude_code_session_id": self._claude_session_id,
+                "ghidra_install_dir": self._install_dir,
+                "open_projects": [
+                    {
+                        "session_id": rec.session_id,
+                        "project_location": rec.project_location,
+                        "project_name": rec.project_name,
+                        "lockfile": str(
+                            Path(rec.project_location) / f"{rec.project_name}.lock"
+                        ),
+                        "program_name": rec.program_name,
+                    }
+                    for rec in self._sessions.values()
+                ],
+            }
+            tmp = self._sidecar_path.with_suffix(".json.tmp")
+            tmp.write_text(json.dumps(payload, indent=2))
+            tmp.replace(self._sidecar_path)
+        except Exception:
+            # Sidecar is advisory; never let a write failure kill the backend.
+            pass
+
+    def _remove_sidecar(self) -> None:
+        with suppress(FileNotFoundError, OSError):
+            self._sidecar_path.unlink()
+
+    def shutdown(self) -> None:
+        if self._shutdown_called:
+            return
+        self._shutdown_called = True
+        for session_id in list(self._sessions):
+            with suppress(Exception):
+                self.session_close(session_id)
+        with suppress(Exception):
+            self._executor.shutdown(wait=False)
+        self._remove_sidecar()
+
+    def install_signal_handlers(self) -> None:
+        """Wire SIGTERM/SIGINT to shutdown(). Call once from the entry point."""
+
+        def _handler(signum, _frame):
+            try:
+                self.shutdown()
+            finally:
+                # Re-raise default behavior so the process actually exits.
+                signal.signal(signum, signal.SIG_DFL)
+                os.kill(os.getpid(), signum)
+
+        for sig in (signal.SIGTERM, signal.SIGINT):
+            with suppress(ValueError, OSError):
+                signal.signal(sig, _handler)
